# Environment Variables Configuration
# Copy this file to .env for local development (never commit .env to git)

# MongoDB Connection (REQUIRED)
# Put the real URI only in your private .env or deployment environment variables.
# Example format:
# mongodb+srv://<set-in-private-env>
MONGODB_URI=SET_IN_PRIVATE_ENV_ONLY

# Twilio SMS Configuration (Optional - for SMS reminder features)
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890
TWILIO_DEFAULT_COUNTRY=+880

# Note: On Render.com, set these in the Environment section of your service dashboard
# DO NOT put real credentials in this file - it's just an example!
